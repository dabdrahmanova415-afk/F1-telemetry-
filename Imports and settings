import paho.mqtt.client as mqtt
import json
import time
import random
from datetime import datetime
import threading
import pandas as pd
import plotly.graph_objs as go
from IPython.display import clear_output, display

BROKER = "broker.emqx.io"   
PORT = 1883

TOPIC_TELEMETRY = "f1/student/telemetry"
TOPIC_TIRES = "f1/student/tires"
TOPIC_FUEL = "f1/student/fuel"

telemetry_data = []
tires_data = []
fuel_data = []
pit_recommendations = []


def on_connect(client, userdata, flags, rc):
    print("Connected to MQTT broker")
    client.subscribe(TOPIC_TELEMETRY)
    client.subscribe(TOPIC_TIRES)
    client.subscribe(TOPIC_FUEL)

def on_message(client, userdata, msg):
    global telemetry_data, tires_data, fuel_data, pit_recommendations
    try:
        payload = json.loads(msg.payload.decode())
        payload['timestamp'] = datetime.now()
        if msg.topic == TOPIC_TELEMETRY:
            telemetry_data.append(payload)
            
            if len(telemetry_data) > 200:
                telemetry_data.pop(0)
        elif msg.topic == TOPIC_TIRES:
            tires_data.append(payload)
            if len(tires_data) > 200:
                tires_data.pop(0)
            if payload['wear'] > 0.8:
                pit_recommendations.append({
                    "timestamp": datetime.now(),
                    "recommendation": "Pit now - high tire wear",
                    "wear": payload['wear']
                })
        elif msg.topic == TOPIC_FUEL:
            fuel_data.append(payload)
            if len(fuel_data) > 200:
                fuel_data.pop(0)
            if payload['level'] < 15:
                pit_recommendations.append({
                    "timestamp": datetime.now(),
                    "recommendation": "Pit now - low fuel",
                    "fuel": payload['level']
                })
    except Exception as e:
        print("Error processing message:", e)
